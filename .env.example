# ============================================================
# FemVerse OB/GYN Assistant - environment configuration
# Copy this file to `.env` and fill in the values for your environment.
# ============================================================

# ---- Model -------------------------------------------------
MODEL_NAME=gemini-flash-latest

# ---- Gemini access (pick ONE block) ------------------------

# Block A: Google AI Studio (API key)
GOOGLE_GENAI_USE_VERTEXAI=0
GOOGLE_API_KEY=replace-with-your-google-ai-studio-key

# Block B: Vertex AI (uncomment to use, comment Block A above)
# GOOGLE_GENAI_USE_VERTEXAI=1
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# ---- Memory Bank (Vertex Agent Engine) ---------------------
# Numeric ID of the Agent Engine instance hosting your Memory Bank.
# Required when GOOGLE_GENAI_USE_VERTEXAI=1.
AGENT_ENGINE_ID=

# ---- Session persistence (SQLAlchemy URL) ------------------
# Optional. If unset, femverse/sessions/service.py::get_database_url() is called.
# Examples:
#   sqlite:///./femverse_sessions.db
#   postgresql+psycopg2://user:pass@host:5432/femverse
#   mysql+pymysql://user:pass@host:3306/femverse
#   mssql+pyodbc://user:pass@host/femverse?driver=ODBC+Driver+17+for+SQL+Server
SESSION_DB_URL=
